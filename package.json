{
  "name": "is-private-ip",
  "version": "0.0.0",
  "description": "Tiny utility to detect private/local/non-public IPv4 and IPv6 addresses.",
  "keywords": [
    "ip",
    "ipv4",
    "ipv6",
    "link-local",
    "network",
    "non-public-ip",
    "private-ip",
    "rfc1918"
  ],
  "homepage": "https://github.com/ntnyq/is-private-ip#readme",
  "bugs": {
    "url": "https://github.com/ntnyq/is-private-ip/issues"
  },
  "license": "MIT",
  "author": {
    "name": "ntnyq",
    "email": "ntnyq13@gmail.com"
  },
  "repository": "ntnyq/is-private-ip",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build",
    "release": "run-s release:check release:version",
    "release:check": "run-s format:check lint typecheck test",
    "release:version": "bumpp",
    "test": "vitest run",
    "test:bench": "vitest bench",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@ntnyq/tsconfig": "^3.1.0",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "^7.0.0-dev.20260527.2",
    "bumpp": "^11.1.0",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "npm-run-all2": "^9.0.1",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "tsdown": "^0.22.0",
    "tsnapi": "^0.3.3",
    "vitest": "^4.1.7"
  },
  "nano-staged": {
    "*.{js,ts,mjs,tsx}": "oxlint --fix",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "packageManager": "pnpm@11.4.0"
}
